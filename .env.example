# --- Database ---
# Local dev: points to the postgres container in docker-compose
DATABASE_URL=postgresql://channelmind:channelmind@db:5432/channelmind
# VM / prod: override with your Neon connection string
# DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Storage ---
DATA_DIR=/data
GCS_BUCKET=your-gcs-bucket-name

# --- Google Cloud (service account key mounted at /secrets/sa.json) ---
GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa.json
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_REGION=us-central1

# --- Gemini ---
GEMINI_MODEL=gemini-2.5-flash

# --- Pinecone ---
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=channelmind-transcripts
PINECONE_ENV=us-east-1-aws

# --- YouTube (optional: uses yt-dlp flat playlist if not set) ---
YOUTUBE_API_KEY=

# --- PyTorch CUDA variant for the worker ---
# cu118  -> CUDA 11.8 (older GPUs)
# cu121  -> CUDA 12.1 (default, matches Dockerfile.worker base)
# cu124  -> CUDA 12.4 (newer GPUs)
# cpu    -> no GPU (use with docker-compose.cpu.yml)
TORCH_CUDA_TAG=cu121

# --- Whisper inference device ---
# cuda (default, GPU), cpu (slower but no GPU required)
WHISPER_DEVICE=cuda

# --- Local storage retention policy ---
# delete_all: remove all local files after success/failure
# keep_transcript_on_failure: on failed jobs keep transcript files only
VIDEO_RETENTION_MODE=delete_all
